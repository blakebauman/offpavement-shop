# Test environment - used by integration/unit tests
# DB_* vars are required by @medusajs/test-utils for pg-god (createDatabase/dropDatabase)
# See: https://docs.medusajs.com/resources/troubleshooting/database-errors
DB_HOST=localhost
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_PORT=5432

DATABASE_URL=postgres://postgres:postgres@localhost:5432/offpavement_store_test
REDIS_URL=redis://localhost:6379
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000
JWT_SECRET=test-secret
COOKIE_SECRET=test-cookie-secret
