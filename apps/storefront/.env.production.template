# Production Environment Variables for Vercel
# Add these to your Vercel project settings

# Your Medusa backend URL (Railway)
MEDUSA_BACKEND_URL=https://your-backend.railway.app
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://your-backend.railway.app

# Publishable API key from Medusa admin
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...

# Your storefront URL
NEXT_PUBLIC_BASE_URL=https://your-storefront.vercel.app

# Default region
NEXT_PUBLIC_DEFAULT_REGION=us

# Stripe publishable key (use live key for production)
NEXT_PUBLIC_STRIPE_KEY=pk_live_...

# Revalidation secret - CHANGE THIS to a secure random string
REVALIDATE_SECRET=your-secure-revalidation-secret

# Optional: Sanity CMS
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
